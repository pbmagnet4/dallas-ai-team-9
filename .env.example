# NavFlow — Environment Variables
# Copy to .env.local (never commit .env.local)

# ── Google OAuth (shared OAuth app — Nithin owns verification) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ── Google Search Console ────────────────────────────────────────────────────
# Scoped to webmasters.readonly — obtained via OAuth user flow
GSC_REFRESH_TOKEN=

# ── GA4 / BigQuery ───────────────────────────────────────────────────────────
# Service account JSON for BigQuery Export reads (Krishna owns provisioning)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/bigquery-service-account.json
GA4_PROJECT_ID=
GA4_DATASET_ID=
# BigQuery export table prefix (usually "events_")
GA4_TABLE_PREFIX=events_

# ── DataForSEO ───────────────────────────────────────────────────────────────
# Edward holds the key; distribute via team 1Password vault
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# Spend limit: $50/month cap during development; raise for production
# Set at: https://app.dataforseo.com/api-access/spending-limits

# ── OpenRouter ───────────────────────────────────────────────────────────────
# Single key for all LLM calls. Edward owns the account.
# Spend limit: $20/month during development. Set at openrouter.ai/settings/limits
# Models used: google/gemini-2.5-flash (volume) + anthropic/claude-sonnet-4-6 (synthesis)
OPENROUTER_API_KEY=
OPENROUTER_VOLUME_MODEL=google/gemini-2.5-flash
OPENROUTER_SYNTHESIS_MODEL=anthropic/claude-sonnet-4-6

# ── Supabase ─────────────────────────────────────────────────────────────────
# Krishna / Raj own provisioning. Project URL from supabase.com dashboard.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Crawl4AI ─────────────────────────────────────────────────────────────────
# Self-hosted on Mac Pro for development; move to AWS for production
CRAWL4AI_BASE_URL=http://192.168.2.2:11235

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
